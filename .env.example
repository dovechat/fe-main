# Account API (auth, tenants, lines, billing)
# Важно: /api/v1 в конце — auth.js склеивает URL как ${VITE_API_URL}/auth/login
VITE_API_URL=http://localhost:8070/api/v1
VITE_ACCOUNT_URL=http://localhost:8070/api/v1

# Chat (REST идёт через VITE_API_URL на mock :8070; WS без Docker не работает — это нормально)
VITE_CHAT_URL=http://localhost:8070
VITE_WS_URL=ws://localhost:8070/
VITE_STORAGE_URL=http://localhost:8001/storage
VITE_TELEGRAM_API_URL=http://localhost:8000

# --- Запуск ---
# 1) Реальный бэкенд: docker compose up в dchat/account (см. dchat/README.md)
# 2) Без Docker: npm run mock:api  (в другом терминале) + npm run dev
